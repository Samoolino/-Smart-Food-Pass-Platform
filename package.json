{
  "name": "smart-food-stamp",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "contracts:test": "pnpm --filter @smart-food-stamp/contracts test",
    "contracts:coverage": "pnpm --filter @smart-food-stamp/contracts coverage",
    "contracts:deploy:local": "pnpm --filter @smart-food-stamp/contracts deploy:local",
    "contracts:deploy:testnet": "pnpm --filter @smart-food-stamp/contracts deploy:testnet",
    "contracts:deploy:mainnet": "pnpm --filter @smart-food-stamp/contracts deploy:mainnet",
    "db:migrate": "turbo run db:migrate",
    "seed:products": "turbo run seed:products",
    "seed:merchants": "turbo run seed:merchants"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.6.3",
    "eslint": "^9.0.0",
    "prettier": "^3.3.3"
  }
}
