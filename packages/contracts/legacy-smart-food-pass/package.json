    "@types/chai": "^4.3.10",
    "@types/mocha": "^10.0.6",
    "chai": "^4.3.10",
    "ethers": "^6.7.1",
    "mocha": "^10.2.0",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.1",
    "typechain": "^8.3.2",
    "typescript": "^5.2.2",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
