{
  "name": "@smart-food-stamp/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "hardhat compile",
    "test": "forge test -vvv",
    "coverage": "forge coverage",
    "lint": "prettier --check .",
    "deploy:local": "forge script script/DeployLocal.s.sol:DeployLocalScript --rpc-url $RPC_URL_LOCAL --broadcast",
    "deploy:testnet": "forge script script/DeployTestnet.s.sol:DeployTestnetScript --rpc-url $RPC_URL_TESTNET --broadcast --verify"
  },
  "devDependencies": {
    "hardhat": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^6.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "forge-std": "latest",
    "typescript": "^5.6.3"
  }
}
